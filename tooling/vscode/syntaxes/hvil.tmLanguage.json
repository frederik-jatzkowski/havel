{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Havel Intermediate Language",
	"patterns": [
		{
			"include": "#misc"
		}
	],
	"repository": {
		"misc": {
			"patterns": [
				{
					"name": "keyword.structure.hvil",
					"match": "\\b(func|declare|block)\\b"
				},
				{
					"name": "comment.line.double-slash.hvil",
					"match": "//.*$"
				},
				{
					"name": "keyword.control.hvil",
					"match": "\\b(if|then|else|return)\\b"
				},
				{
					"name": "support.type.primitive.hvil",
					"match": "\\b(8|16|32|64)\\b"
				},
				{
				  "name": "constant.numeric.hex.hvil",
				  "match": "\\b0b[01]+\\b"
				},
				{
				  "name": "variable.name.identifier.hvil",
				  "match": "\\b([a-z][0-9a-z_]*)\\b"
				}
			]
		}
	},
	"scopeName": "source.hvil"
}