package main

import (
    "math"
)

type Point class {
    x : int;
    y : int;
}

method<Point> Distance(other *Point): int {
    return math.sqrt(
        math.pow(
            math.abs(this.x - other.x),
            2
        ),
        math.pow(
            math.abs(this.x - other.x),
            2
        )
    )
}