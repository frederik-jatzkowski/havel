// This test implements a linked list where each node is allocated on the heap.
func main() {
    declare (
        head : { 1 byte, ref },
        item : 1 byte
    );

    block entry {
        $list : ref = mem.ptr(head);
        head[0] = 1;

        item = 2;
        call.local.append($list, item);
        item = 4;
        call.local.append($list, item);
        item = 8;
        call.local.append($list, item);
        item = 16;
        call.local.append($list, item);
        item = 32;
        call.local.append($list, item);
        item = 64;
        call.local.append($list, item);

        $double : func(ref) = call.ptr(double);
        call.local.foreach($list, $double);

        $print : func(ref) = call.ptr(print);
        call.local.foreach($list, $print);
    } return;
}

func double(node_ptr : ref) {
    block entry {
        $val_ptr : ref = mem.element_ptr(node_ptr, { 1 byte, ref }, 0, self[0]);
        $val : 1 byte = mem.load($val_ptr);
        $res : 1 byte = alu.add_u($val, $val);
        mem.store($val_ptr, $res);
    } return;
}

func print(node_ptr : ref) {
    block entry {
        $val_ptr : ref = mem.element_ptr(node_ptr, { 1 byte, ref }, 0, self[0]);
        $val : 1 byte = mem.load($val_ptr);

        debug.dump($val);
    } return;
}

func append(list : ref, elem : 1 byte) {
    declare (
        node : { 1 byte, ref },
        last : ref
    );

    block entry {
        $last : ref = mem.ptr(last);
        call.local.last(list, $last);

        node[0] = alu.move(elem);
        node[1] = 0b0;

        $size : 8 byte = mem.sizeof({ 1 byte, ref });
        $node : ref = mem.alloc($size);

        $stack_node : ref = mem.ptr(node);
        mem.copy($node, $stack_node, $size);

        $prev_next_ptr : ref = mem.element_ptr(last, { 1 byte, ref }, 0, self[1]);
        mem.store($prev_next_ptr, $node);
    } return;
}

func last(list : ref, result : ref) {
    declare (
        curr : ref
    );

    block entry {
        curr = alu.move(list);
    } goto loop_head;

    block loop_head {
        $null : ref = 0b0;
        $is_null : 1 byte = alu.eq(curr, $null);
    } if $is_null then exit else body;

    block body {
        $next_ptr_addr : ref = mem.element_ptr(curr, { 1 byte, ref }, 0, self[1]);
        mem.store(result, curr);
        curr = mem.load($next_ptr_addr);
    } goto loop_head;

    block exit {} return;
}

func foreach(head : ref, f : func(ref)) {
    declare (
        curr : ref
    );

    block entry {
        curr = alu.move(head);
    } goto loop_head;

    block loop_head {
        $null : ref = 0b0;
        $is_null : 1 byte = alu.eq(curr, $null);
    } if $is_null then exit else body;

    block body {
        call.dyn.f(curr);
        
        $next_ptr_addr : ref = mem.element_ptr(curr, { 1 byte, ref }, 0, self[1]);
        curr = mem.load($next_ptr_addr);
    } goto loop_head;

    block exit {
    } return;
}
