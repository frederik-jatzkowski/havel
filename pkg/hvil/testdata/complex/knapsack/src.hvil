// 0-1 Knapsack using recursion (Branch and Bound)
// We use a global variable (on heap) to store the maximum value found so far.
// Items are also stored on the heap.

func main() {
    declare (
        instance : {
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte },
            { 8 byte, 8 byte }
        },
        max_val : 8 byte
    );

    block entry {
        // Capacity: 178
        $capacity : 8 byte = 0b10110010;

        // Number of items: 25
        $n : 8 byte = 0b11001;

        $items : ref = mem.ptr(instance);

        // Item 0: weight 10, value 60
        $w0 : 8 byte = 0b1010;
        $v0 : 8 byte = 0b111100;
        instance[0][0] = 0b1010;
        instance[0][1] = alu.move($v0);

        // Item 1: weight 20, value 100
        $w1 : 8 byte = 0b10100;
        $v1 : 8 byte = 0b1100100;
        instance[1][0] = alu.move($w1);
        instance[1][1] = alu.move($v1);

        // Item 2: weight 30, value 120
        $w2 : 8 byte = 0b11110;
        $v2 : 8 byte = 0b1111000;
        instance[2][0] = alu.move($w2);
        instance[2][1] = alu.move($v2);

        // Item 3: weight 15, value 70
        $w3 : 8 byte = 0b1111;
        $v3 : 8 byte = 0b1000110;
        instance[3][0] = alu.move($w3);
        instance[3][1] = alu.move($v3);

        // Item 4: weight 5, value 30
        $w4 : 8 byte = 0b101;
        $v4 : 8 byte = 0b11110;
        instance[4][0] = alu.move($w4);
        instance[4][1] = alu.move($v4);

        // Item 5: weight 25, value 80
        $w5 : 8 byte = 0b11001;
        $v5 : 8 byte = 0b1010000;
        instance[5][0] = alu.move($w5);
        instance[5][1] = alu.move($v5);

        // Item 6: weight 8, value 40
        $w6 : 8 byte = 0b1000;
        $v6 : 8 byte = 0b101000;
        instance[6][0] = alu.move($w6);
        instance[6][1] = alu.move($v6);

        // Item 7: weight 12, value 50
        $w7 : 8 byte = 0b1100;
        $v7 : 8 byte = 0b110010;
        instance[7][0] = alu.move($w7);
        instance[7][1] = alu.move($v7);

        // Item 8: weight 18, value 90
        $w8 : 8 byte = 0b10010;
        $v8 : 8 byte = 0b1011010;
        instance[8][0] = alu.move($w8);
        instance[8][1] = alu.move($v8);

        // Item 9: weight 7, value 45
        $w9 : 8 byte = 0b111;
        $v9 : 8 byte = 0b101101;
        instance[9][0] = alu.move($w9);
        instance[9][1] = alu.move($v9);

        // Item 10: weight 11, value 55
        $w10 : 8 byte = 0b1011;
        $v10 : 8 byte = 0b110111;
        instance[10][0] = alu.move($w10);
        instance[10][1] = alu.move($v10);

        // Item 11: weight 14, value 65
        $w11 : 8 byte = 0b1110;
        $v11 : 8 byte = 0b1000001;
        instance[11][0] = alu.move($w11);
        instance[11][1] = alu.move($v11);

        // Item 12: weight 9, value 48
        $w12 : 8 byte = 0b1001;
        $v12 : 8 byte = 0b110000;
        instance[12][0] = alu.move($w12);
        instance[12][1] = alu.move($v12);

        // Item 13: weight 22, value 95
        $w13 : 8 byte = 0b10110;
        $v13 : 8 byte = 0b1011111;
        instance[13][0] = alu.move($w13);
        instance[13][1] = alu.move($v13);

        // Item 14: weight 6, value 38
        $w14 : 8 byte = 0b110;
        $v14 : 8 byte = 0b100110;
        instance[14][0] = alu.move($w14);
        instance[14][1] = alu.move($v14);

        // Item 15: weight 13, value 52
        $w15 : 8 byte = 0b1101;
        $v15 : 8 byte = 0b110100;
        instance[15][0] = alu.move($w15);
        instance[15][1] = alu.move($v15);

        // Item 16: weight 17, value 75
        $w16 : 8 byte = 0b10001;
        $v16 : 8 byte = 0b1001011;
        instance[16][0] = alu.move($w16);
        instance[16][1] = alu.move($v16);

        // Item 17: weight 21, value 88
        $w17 : 8 byte = 0b10101;
        $v17 : 8 byte = 0b1011000;
        instance[17][0] = alu.move($w17);
        instance[17][1] = alu.move($v17);

        // Item 18: weight 19, value 82
        $w18 : 8 byte = 0b10011;
        $v18 : 8 byte = 0b1010010;
        instance[18][0] = alu.move($w18);
        instance[18][1] = alu.move($v18);

        // Item 19: weight 4, value 25
        $w19 : 8 byte = 0b100;
        $v19 : 8 byte = 0b11001;
        instance[19][0] = alu.move($w19);
        instance[19][1] = alu.move($v19);

        // Item 20: weight 28, value 110
        $w20 : 8 byte = 0b11100;
        $v20 : 8 byte = 0b1101110;
        instance[20][0] = alu.move($w20);
        instance[20][1] = alu.move($v20);

        // Item 21: weight 24, value 105
        $w21 : 8 byte = 0b11000;
        $v21 : 8 byte = 0b1101001;
        instance[21][0] = alu.move($w21);
        instance[21][1] = alu.move($v21);

        // Item 22: weight 16, value 68
        $w22 : 8 byte = 0b10000;
        $v22 : 8 byte = 0b1000100;
        instance[22][0] = alu.move($w22);
        instance[22][1] = alu.move($v22);

        // Item 23: weight 11, value 58
        $w23 : 8 byte = 0b1011;
        $v23 : 8 byte = 0b111010;
        instance[23][0] = alu.move($w23);
        instance[23][1] = alu.move($v23);

        // Item 24: weight 32, value 130
        $w24 : 8 byte = 0b100000;
        $v24 : 8 byte = 0b10000010;
        instance[24][0] = alu.move($w24);
        instance[24][1] = alu.move($v24);

        $max_val_ptr : ref = mem.ptr(max_val);
        $zero : 8 byte = 0b0;
        max_val = alu.move($zero);

        // call solve(index, current_weight, current_value, items, n, capacity, max_val_ptr)
        $idx : 8 byte = 0b0;
        $cw : 8 byte = 0b0;
        $cv : 8 byte = 0b0;
        call.local.solve($idx, $cw, $cv, $items, $n, $capacity, $max_val_ptr);

        // Dump result
        debug.dump(max_val);
    } return;
}

func add_item(items : ref, index : 8 byte, weight : 8 byte, value : 8 byte) {
    block entry {
        $w_ptr : ref = mem.element_ptr(items, { 8 byte, 8 byte }, index, self[0]);
        mem.store($w_ptr, weight);

        $v_ptr : ref = mem.element_ptr(items, { 8 byte, 8 byte }, index, self[1]);
        mem.store($v_ptr, value);
    } return;
}

func solve(
    index : 8 byte,
    curr_w : 8 byte,
    curr_v : 8 byte,
    items : ref,
    n : 8 byte,
    capacity : 8 byte,
    max_val_ptr : ref
) {
    declare (
        new_w : 8 byte,
        new_v : 8 byte
    );
    block entry {
        // Base case: index == n
        $at_end : 1 byte = alu.eq(index, n);
    } if $at_end then update_max else check_weight;

    block check_weight {
        // If current weight > capacity, return
        $too_heavy : 1 byte = alu.lt_u(capacity, curr_w);
    } if $too_heavy then ret_block else branch;

    block update_max {
        $best_so_far : 8 byte = mem.load(max_val_ptr);
        $is_better : 1 byte = alu.lt_u($best_so_far, curr_v);
    } if $is_better then set_new_best else ret_block;

    block set_new_best {
        mem.store(max_val_ptr, curr_v);
    } goto ret_block;

    block branch {
        // Recursive calls
        $one : 8 byte = 0b1;
        $next_idx_val : 8 byte = alu.add_u(index, $one);

        // Option 1: Don't include items[index]
        call.local.solve($next_idx_val, curr_w, curr_v, items, n, capacity, max_val_ptr);

        // Option 2: Include items[index] (if it fits)
        $item_w_ptr : ref = mem.element_ptr(items, { 8 byte, 8 byte }, index, self[0]);
        $w : 8 byte = mem.load($item_w_ptr);

        $item_v_ptr : ref = mem.element_ptr(items, { 8 byte, 8 byte }, index, self[1]);
        $v : 8 byte = mem.load($item_v_ptr);

        new_w = alu.add_u(curr_w, $w);
        new_v = alu.add_u(curr_v, $v);

        // Simple bound: only recurse if new_w <= capacity
        // new_w <= capacity is equivalent to NOT (capacity < new_w)
        $too_heavy_to_include : 1 byte = alu.lt_u(capacity, new_w);
    } if $too_heavy_to_include then ret_block else include_item;

    block include_item {
        $one : 8 byte = 0b1;
        $next_idx_val_inc : 8 byte = alu.add_u(index, $one);
        call.local.solve($next_idx_val_inc, new_w, new_v, items, n, capacity, max_val_ptr);
    } goto ret_block;

    block ret_block {
    } return;
}
