
func main() {
    block entry {
        $n : 8 byte = 0b1101;
        $steps : 8 byte = call.local.solve_collatz($n);
        debug.dump($steps);
    } return;
}

func solve_collatz(n : 8 byte) -> (steps : 8 byte) {
    block entry {
        steps = 0b0;
    } goto loop_head;

    block loop_head {
        debug.dump(n);
        steps = call.local.inc(steps);
        $one : 8 byte = 0b1;
        $check : 1 byte = alu.eq(n, $one);
    } if $check then exit else decide;

    block decide {
        $check : 1 byte = call.local.is_even(n);
    } if $check then divide else multiply;

    block divide {
        $two : 8 byte = 0b10;
        n = alu.div_u(n, $two);
    } goto loop_head;

    block multiply {
        $three : 8 byte = 0b11;
        n = alu.mul_u(n, $three);
        n = call.local.inc(n);
    } goto loop_head;

    block exit {} return;
}

func is_even(n : 8 byte) -> (result : 1 byte) {
    block entry {
        $two : 8 byte = 0b10;
        $n_mod_two : 8 byte = alu.mod_u(n, $two);
        $zero : 8 byte = 0b0;
        result = alu.eq($n_mod_two, $zero);
    } return;
}

func inc(value : 8 byte) -> (result : 8 byte) {
    block entry {
        $one : 8 byte = 0b1;
        result = alu.add_u(value, $one);
    } return;
}
