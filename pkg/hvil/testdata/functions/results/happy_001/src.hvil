
func main() {
    declare (
        dice : 1 byte
    );

    block entry {
        $dice_ptr : ref = mem.ptr(dice);
        call.local.throw_dice($dice_ptr);
        debug.dump(dice);
    } return;
}

func throw_dice(result_ptr : ref) {
    block entry {
        $res : 1 byte = 0b101010;
        mem.store(result_ptr, $res);
    } return;
}
