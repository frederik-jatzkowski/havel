func main() {
    declare (
        res : 1 byte
    );
    block entry {
        $f : func(1 byte, ref) = call.ptr(identity);
        // This should fail because of parameter count mismatch
        $arg1 : 1 byte = 0b1;
        $arg2 : 1 byte = 0b10;
        $res_ptr : ref = mem.ptr(res);
        call.dyn.$f($arg1, $arg2, $res_ptr);
        debug.dump(res);
    } return;
}

func identity(x : 1 byte, result_ptr : ref) {
    declare (
        y : 1 byte
    );
    block entry {
        y = alu.move(x);
        mem.store(result_ptr, y);
    } return;
}
