
func main() {
    declare (
        res_val : 1 byte
    );
    block entry {
        $size : 8 byte = 0b1;
        $len : 8 byte = 0b101;
        $total : 8 byte = alu.mul_u($size, $len);
        $zero : 1 byte = 0b0;

        $ptr : ref = mem.alloc($total);

        $fill : func(ref, ref) = call.ptr(fill);
        $sum : func(ref, ref) = call.ptr(sum);

        $res_ptr : ref = mem.ptr(res_val);
        call.local.reduce($ptr, $size, $len, $zero, $fill, $res_ptr);

        call.local.reduce($ptr, $size, $len, $zero, $sum, $res_ptr);

        debug.dump(res_val);
    } return;
}

func fill(total : ref, curr : ref) {
    block entry {
        $two : 1 byte = 0b10;
        mem.store(curr, $two);
    } return;
}

func sum(total : ref, curr : ref) {
    block entry {
        $total : 1 byte = mem.load(total);
        // debug.dump($total);
        $curr : 1 byte = mem.load(curr);
        // debug.dump($curr);
        $result : 1 byte = alu.add_u($total, $curr);
        // debug.dump($result);
        mem.store(total, $result);
    } return;
}

func reduce(
        ptr : ref,
        size : 8 byte,
        len : 8 byte,
        init : 1 byte,
        action : func(ref, ref),
        result_ptr : ref
    ) {
    declare (
        i : 8 byte,
        result_val : 1 byte
    );

    block entry {
        i = 0b0;
        result_val = alu.move(init);
    } goto head;

    block head {
        $done : 1 byte = alu.eq(i, len);
    } if $done then exit else body;

    block body {
        $offset : 8 byte = alu.mul_u(size, i);
        $elem : ref = alu.add_u(ptr, $offset);

        $result_val_ptr : ref = mem.ptr(result_val);

        call.dyn.action($result_val_ptr, $elem);

        $one : 8 byte = 0b1;
        i = alu.add_u(i, $one);
    } goto head;

    block exit {
        mem.store(result_ptr, result_val);
    } return;
}
