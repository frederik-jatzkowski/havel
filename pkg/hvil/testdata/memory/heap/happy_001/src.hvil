
func main() {
    block entry {
        $size : 8 byte = 0b1;
        $ptr : ref = mem.alloc($size);
        $one : 1 byte = 0b1;
        mem.store($ptr, $one);
        call.local.inc_ref($ptr);
        $n : 1 byte = mem.load($ptr);
        debug.dump($n);
        mem.free($ptr);
    } return;
}

func inc_ref(value : ref) {
    block entry {
        $loaded : 1 byte = mem.load(value);
        $one : 1 byte = 0b1;
        $result : 1 byte = alu.add_u($loaded, $one);
        mem.store(value, $result);
    } return;
}
