
func main() {
    block entry {
        $n : 1 byte = 0b1;
        call.local.volatile($n);
    } return;
}

func volatile(n : 1 byte) {
    block entry {
        mem.ptr(n); // make it volatile
        call.local.noop(); // check if save - restore logic works
        debug.dump(n);
    } return;
}

func noop() {
    block entry {} return;
}
