
func main() {
    declare (
        res_ptr : ref
    );
    block entry {
        $res_ptr_ptr : ref = mem.ptr(res_ptr);
        call.local.create_dangling($res_ptr_ptr);
        call.local.print(res_ptr);
        call.local.overwrite_dangling();
        call.local.print(res_ptr);
    } return;
}

func create_dangling(result_ptr : ref) {
    declare (n : 4 byte );

    block entry {
        n = 0b1;
        $ptr : ref = mem.ptr(n);
        mem.store(result_ptr, $ptr);
    } return;
}

func overwrite_dangling() {
    declare (n : 4 byte );

    block entry {
        n = 0b10;
        mem.ptr(n); // avoid optimizations
    } return;
}


func print(ptr : ref) {
    block entry {
        $value : 4 byte = mem.load(ptr);
        debug.dump($value);
    } return;
}
