
func main() {
    declare (
        dangling : ref
    );

    block entry {
        $ptr : ref = mem.ptr(dangling);
        call.local.create_dangling($ptr);

        call.local.print(dangling);
        call.local.overwrite_dangling($ptr);
        call.local.print(dangling);
    } return;
}

func create_dangling(result: ref) {
    declare (n : 1 byte );

    block entry {
        n = 0b1;
        $result : ref = mem.ptr(n);
        mem.store(result, $result);
    } return;
}

func overwrite_dangling(result: ref) {
    declare (n : 1 byte );

    block entry {
        n = 0b10;
        mem.ptr(n); // avoid optimizations
    } return;
}


func print(ptr : ref) {
    block entry {
        $value : 1 byte = mem.load(ptr);
        debug.dump($value);
    } return;
}
