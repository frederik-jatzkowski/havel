
func main() {
    declare (
        n : 8 byte
    );

    block entry {
        $ptr : ref = mem.ptr(n);

        $one : 8 byte = 0b1;
        mem.store($ptr, $one);

        call.local.inc_ref($ptr);

        debug.dump(n);
    } return;
}

func inc_ref(value : ref) {
    block entry {
        $loaded : 8 byte = mem.load(value);
        $one : 8 byte = 0b1;
        $result : 8 byte = alu.add_u($loaded, $one);
        mem.store(value, $result);
    } return;
}
