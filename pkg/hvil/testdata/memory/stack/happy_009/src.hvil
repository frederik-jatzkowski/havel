
func main() {
    block entry {
        $ptr : ref = call.local.create_dangling();
        call.local.print($ptr);
        call.local.overwrite_dangling();
        call.local.print($ptr);
    } return;
}

func create_dangling() -> (result: ref) {
    declare (n : 8 byte );

    block entry {
        n = 0b1;
        result = mem.ptr(n);
    } return;
}

func overwrite_dangling() -> (result: ref) {
    declare (n : 8 byte );

    block entry {
        n = 0b10;
        mem.ptr(n); // avoid optimizations
    } return;
}


func print(ptr : ref) {
    block entry {
        $value : 8 byte = mem.load(ptr);
        debug.dump($value);
    } return;
}
