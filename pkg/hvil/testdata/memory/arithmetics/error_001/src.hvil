
func main() {
    declare (
        n : 1 byte
    );

    block entry {
        $size : 8 byte = mem.sizeof(4 byte);
        $len : 8 byte = 0b101;
        $total : 8 byte = alu.mul_u($size, $len);

        $ptr : ref = mem.alloc($total);

        call.local.fill($ptr, $len); // segfault in here
    } return;
}

func fill(ptr : ref, len : 8 byte) {
    declare (
        i : 8 byte
    );

    block entry {
        i = 0b0;
    } goto head;

    block head {
        $done : 1 byte = alu.eq(i, len);
    } if $done then exit else body;

    block body {
        $elem : ref = mem.element_ptr(ptr, 8 byte, i);

        $two : 8 byte = 0b10;
        mem.store($elem, $two);

        $one : 8 byte = 0b1;
        i = alu.add_u(i, $one);
    } goto head;

    block exit {} return;
}
