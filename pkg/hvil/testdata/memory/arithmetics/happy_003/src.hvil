
func main() {
    declare (
        n : 4 byte
    );

    block entry {
        $size : 8 byte = 0b100;
        $len : 8 byte = 0b101;
        $total : 8 byte = alu.mul_u($size, $len);

        $ptr : ref = mem.alloc($total);

        call.local.fill($ptr, $size, $len);

        $sum_ptr : ref = mem.ptr(n);
        call.local.sum($ptr, $size, $len, $sum_ptr);

        debug.dump(n);
    } return;
}

func fill(ptr : ref, size : 8 byte, len : 8 byte) {
    declare (
        i : 8 byte
    );

    block entry {
        i = 0b0;
    } goto head;

    block head {
        $done : 1 byte = alu.eq(i, len);
    } if $done then exit else body;

    block body {
        $offset : 8 byte = alu.mul_u(size, i);
        $elem : ref = alu.add_u(ptr, $offset);

        $two : 4 byte = 0b10;
        mem.store($elem, $two);

        $one : 8 byte = 0b1;
        i = alu.add_u(i, $one);
    } goto head;

    block exit {} return;
}

func sum(ptr : ref, size : 8 byte, len : 8 byte, result_ptr : ref) {
    declare (
        i : 8 byte,
        sum_val : 4 byte
    );

    block entry {
        i = 0b0;
        sum_val = 0b0;
    } goto head;

    block head {
        $done : 1 byte = alu.eq(i, len);
    } if $done then exit else body;

    block body {
        $offset : 8 byte = alu.mul_u(size, i);
        $elem : ref = alu.add_u(ptr, $offset);

        $loaded : 4 byte = mem.load($elem);
        sum_val = alu.add_u(sum_val, $loaded);

        $one : 8 byte = 0b1;
        i = alu.add_u(i, $one);
    } goto head;

    block exit {
        mem.store(result_ptr, sum_val);
    } return;
}
