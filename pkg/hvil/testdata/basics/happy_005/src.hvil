
func main() {
    block entry {
        $n0 : 8 byte = 0b1;
        $n1 : 8 byte = 0b1;
        $n2 : 8 byte = alu.add_u($n0, $n1);
        $n3 : 8 byte = alu.add_u($n0, $n2);
        $n4 : 8 byte = alu.add_u($n0, $n3);
        $n5 : 8 byte = alu.add_u($n0, $n4);
        $n6 : 8 byte = alu.add_u($n0, $n5);
        $n7 : 8 byte = alu.add_u($n0, $n6);
        $n8 : 8 byte = alu.add_u($n0, $n7);
        $n9 : 8 byte = alu.add_u($n0, $n8);
        $n10 : 8 byte = alu.add_u($n0, $n9);
        debug.dump($n10);
    } return;
}
